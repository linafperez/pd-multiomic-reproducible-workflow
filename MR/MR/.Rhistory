pd_snps <- pd_data %>%
mutate(
or = exp(beta.outcome),
or_lci95 = exp(beta.outcome - 1.96 * se.outcome),
or_uci95 = exp(beta.outcome + 1.96 * se.outcome)
) %>%
dplyr::select(
Region,
taxon,
SNP,
hgnc_symbol,
pval.outcome,
or,
or_lci95,
or_uci95
)
