# DATA PREPARATION
# Format OR and 95% CI
PD_MR_combined$`OR (95% CI)` <- sprintf("%.2f (%.2f to %.2f)",
PD_MR_combined$or,
PD_MR_combined$or_lci95,
PD_MR_combined$or_uci95)
# Format p-values: scientific notation if <0.001, else 3 decimal places
PD_MR_combined$`P-value` <- ifelse(PD_MR_combined$pval < 0.001,
formatC(PD_MR_combined$pval, format = "e", digits = 2),
sprintf("%.3f", PD_MR_combined$pval))
# Calculate standard error from confidence intervals
PD_MR_combined$se <- (log(PD_MR_combined$or_uci95) - log(PD_MR_combined$or))/1.96
# Create blank column that will hold the confidence interval graphics
PD_MR_combined$` ` <- paste(rep(" ", 25), collapse = " ")
# CREATE PLOT DATA FRAME
# Assemble all components into a data frame for plotting
dt <- data.frame(
Method = PD_MR_combined$method,
SNPs = as.character(PD_MR_combined$nsnp),
`OR (95% CI)` = PD_MR_combined$`OR (95% CI)`,
` ` = PD_MR_combined$` `,
`P-value` = PD_MR_combined$`P-value`,
# Numeric versions for calculations (not displayed directly)
estimate = PD_MR_combined$or,
low = PD_MR_combined$or_lci95,
high = PD_MR_combined$or_uci95,
se = PD_MR_combined$se,
stringsAsFactors = FALSE,
check.names = FALSE  # Preserve special characters in column names
)
# DEFINE PLOT THEME
# Customize all visual aspects of the forest plot
tm <- forest_theme(
# Text sizing
base_size = 12,
base_family = "Helvetica",
# Confidence interval appearance
ci_pch = 18,
ci_col = "#1E64B0",
ci_lwd = 2,
ci_alpha = 0.8,
ci_Theight = 0.3,
# Reference line at OR=1
refline_col = "#E41A1C",
refline_lwd = 1.5,
refline_lty = "dashed",
# Spacing and layout
colgap = unit(8, "mm"),
header_height = unit(20, "mm"),
plot_margin = unit(c(1, 2, 1, 1), "cm")
)
# CREATE FOREST PLOT
# Generate the forest plot object
p <- forest(
# Columns to display (in order)
dt[, c("Method", "SNPs", " ", "OR (95% CI)", "P-value")],
est = dt$estimate,
lower = dt$low,
upper = dt$high,
sizes = 0.4,
# Plot configuration
ci_column = 3,
ref_line = 1,
arrow_lab = c("Protective", "Risk"),
x_trans = "log",
xlim = c(0.3, 3),
ticks_at = c(0.3, 0.5, 1, 2, 3),
# Apply our custom theme
theme = tm
)
# DISPLAY THE PLOT
# Render the plot with specified dimensions
plot(p, vp = viewport(width = unit(8, "inches"),
height = unit(2, "inches")))
# To save:
pdf("./Forest/forest_plot.pdf", width = 8, height = 2)  # Adjust dimensions as needed
plot(p)  # Your forest plot object
dev.off()  # Close the graphics device
